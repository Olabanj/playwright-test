# API
API_BASE_URL=https://sandbox-api.remotepass.com

# UI base URLs
FRONTOFFICE_URL=https://sandbox.remotepass.com
BACKOFFICE_URL=https://sandbox-admin.remotepass.com

# Credentials — client (front-office)
CLIENT_EMAIL=client@example.com
CLIENT_PASSWORD=changeme

# Credentials — worker / contractor (front-office)
WORKER_EMAIL=worker@example.com
WORKER_PASSWORD=changeme

# Credentials — admin (back-office) — optional for now
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Optional: bypass header for sandbox endpoints
E2E_SECRET_KEY=

# Optional: gated DB-OTP read layer (core/db) — worker OTP retrieval only.
# See docs/30-decisions/2026-07-08-dmytro-db-otp-layer.md. Absent locally =
# dependent contractor-registration flows self-skip; this is expected, not a bug.
# DB/SSH secrets are CI-only today.
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
